#!/usr/bin/with-contenv bash
# shellcheck shell=bash
#
# Runtime VPN Config Switching Support
#
# This modification allows changing VPN config at runtime by:
# 1. Writing the desired config path to ${VPN_DIR}/.switch-config
# 2. Sending SIGHUP or restarting the openvpn service
#
# The script checks for the override file on each restart, enabling
# hot-swapping VPN servers without container restart.

set -euo pipefail

# shellcheck source=/scripts/logging.sh
source /scripts/logging.sh

if [ "${VPN_ENABLED:-false}" != "true" ]; then
    log "[OpenVPN] VPN disabled (sleeping)"
    exec sleep infinity
fi

# Check for restart signal from backend (written by non-root user)
RESTART_SIGNAL_FILE="/tmp/.openvpn-restart-signal"
if [ -f "$RESTART_SIGNAL_FILE" ]; then
    log "[OpenVPN] restart signal detected, killing existing openvpn process"
    rm -f "$RESTART_SIGNAL_FILE"
    pkill -TERM openvpn 2>/dev/null || true
    # Wait for process to die
    for i in 1 2 3 4 5; do
        if pgrep openvpn >/dev/null 2>&1; then
            sleep 1
        else
            break
        fi
    done
    # Clear persisted s6 env so we use original env var config (not stale switched config)
    rm -f /run/s6/container_environment/OPENVPN_CONFIG_FILE 2>/dev/null || true
    rm -f /var/run/s6/container_environment/OPENVPN_CONFIG_FILE 2>/dev/null || true
    debug_log "[OpenVPN] cleared persisted s6 env files for fresh restart"
fi

# Check for runtime config override
# This file can be written by external tools to change VPN config dynamically
CONFIG_OVERRIDE_FILE="/tmp/.openvpn-switch-config"
debug_log "[OpenVPN] Checking for runtime config override at: $CONFIG_OVERRIDE_FILE"
if [ -f "$CONFIG_OVERRIDE_FILE" ]; then
    OVERRIDE_CONFIG=$(cat "$CONFIG_OVERRIDE_FILE" 2>/dev/null | tr -d '\n')
    debug_log "[OpenVPN] Override config content: $OVERRIDE_CONFIG"
    if [ -n "$OVERRIDE_CONFIG" ] && [ -f "$OVERRIDE_CONFIG" ]; then
        log "[OpenVPN] using runtime override config: $OVERRIDE_CONFIG"
        OPENVPN_CONFIG_FILE="$OVERRIDE_CONFIG"

        # Apply provider-specific fixes and cleanup
        if [ -x "/scripts/openvpn-apply-provider-fixes.sh" ]; then
            debug_log "[OpenVPN] applying provider fixes to override config"
            /scripts/openvpn-apply-provider-fixes.sh "$OPENVPN_CONFIG_FILE" "${OPENVPN_PROVIDER:-}" || true
        fi

        # Note: Delete the switch file so it doesn't persist across restarts
        # This ensures container reboot uses original env, not switched config
        rm -f "$CONFIG_OVERRIDE_FILE"
    else
        debug_log "[OpenVPN] Override config file not found or empty: $OVERRIDE_CONFIG"
    fi
else
    debug_log "[OpenVPN] No runtime override file found"
fi

# Fall back to standard env var if no override
if [ -z "${OPENVPN_CONFIG_FILE:-}" ]; then
    log "[OpenVPN] OPENVPN_CONFIG_FILE not set — init-openvpn-config may have failed"
    exec sleep infinity
fi

openvpn_args=(
    --reneg-sec 0
    --disable-occ
    --auth-nocache
    --mute-replay-warnings
    --data-ciphers-fallback AES-128-GCM
    --pull-filter ignore 'route-ipv6'
    --pull-filter ignore 'ifconfig-ipv6'
    --pull-filter ignore 'tun-ipv6'
    --pull-filter ignore 'dhcp-option DNS6'
    --pull-filter ignore 'reneg-sec'
    --pull-filter ignore 'persist-tun'
    --pull-filter ignore 'block-outside-dns'
)

# Allow user custom options
if [ -n "${OPENVPN_OPTIONS:-}" ]; then
    # shellcheck disable=SC2206
    extra=( ${OPENVPN_OPTIONS} )
    openvpn_args+=( "${extra[@]}" )
fi

openvpn_args+=( --config "${OPENVPN_CONFIG_FILE}" )

# Inject --auth-user-pass if credentials file exists and config doesn't already have it
if [ -n "${OPENVPN_AUTH_FILE:-}" ] && [ -f "${OPENVPN_AUTH_FILE}" ]; then
    if ! grep -Eq '^auth-user-pass' "${OPENVPN_CONFIG_FILE}" 2>/dev/null; then
        openvpn_args+=( --auth-user-pass "${OPENVPN_AUTH_FILE}" )
        debug_log "[OpenVPN] injecting --auth-user-pass ${OPENVPN_AUTH_FILE}"
    fi
fi

debug_log "[OpenVPN] OPENVPN_CONFIG_FILE=${OPENVPN_CONFIG_FILE}"
log "[OpenVPN] starting openvpn"

# Debug: show config file head
if [ -f "${OPENVPN_CONFIG_FILE}" ]; then
    debug_log "[OpenVPN] Config file exists, size: $(wc -c <"${OPENVPN_CONFIG_FILE}") bytes"
    debug_log "[OpenVPN] Config head: $(head -5 "${OPENVPN_CONFIG_FILE}" | tr '\n' ' ')"
else
    log "[OpenVPN] ERROR: Config file not found: ${OPENVPN_CONFIG_FILE}"
    exec sleep 5
fi

log_dir="${VPN_LOG_DIR:-/app/config/logs/openvpn}"
mkdir -p "${log_dir}"
chown -R tuliprox:tuliprox "${log_dir}" 2>/dev/null || true

# Don't use exec so we can capture exit code and log it
openvpn "${openvpn_args[@]}" 2>&1 | s6-log -b n20 s1000000 T "${log_dir}"
